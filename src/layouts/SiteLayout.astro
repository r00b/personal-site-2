---
import Analytics from '@vercel/analytics/astro'
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = "Rob Steilberg",
  description = "Robert Steilberg's home page",
  path = "/"
} = Astro.props;

const siteUrl = new URL(path, Astro.site ?? "https://www.robsteilberg.com");
const backgroundImagePaths = [
  "/assets/site-background-1.webp",
  "/assets/site-background-2.webp",
  "/assets/site-background-3.webp",
  "/assets/site-background-4.webp",
  "/assets/site-background-5.webp",
  "/assets/site-background-6.webp",
];
const defaultBackgroundImagePath = backgroundImagePaths[0];
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{title}</title>
    <meta name="description" content={description}/>
    <link rel="icon" type="image/png" href="/assets/favicon.png"/>
    <link rel="canonical" href={siteUrl.toString()}/>
    <meta property="og:url" content={siteUrl.toString()}/>
    <meta property="og:title" content={title}/>
    <meta property="og:type" content="website"/>
    <meta property="og:description" content={description}/>
    <Analytics/>
</head>
<body style={`--site-background-image: url('${defaultBackgroundImagePath}')`}>
    <div class="site-shell">
        <slot/>
    </div>
    <script is:inline define:vars={{backgroundImagePaths}}>
      const backgrounds = backgroundImagePaths;
      const randomIndex = Math.floor(Math.random() * backgrounds.length);
      const selectedBackground = backgrounds[randomIndex];
      const shell = document.querySelector(".site-shell");

      if (shell instanceof HTMLElement) {
        shell.style.setProperty(
          "--site-background-image",
          `url('${selectedBackground}')`
        );
      }
    </script>
</body>
</html>
